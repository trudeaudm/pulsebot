# Copy to .env and fill in. Never commit .env (it's gitignored).
# Real environment variables always win over values in this file.

PULSE_BASE_RPC=        # e.g. Alchemy Base mainnet HTTPS URL
PULSE_ROBINHOOD_RPC=   # e.g. Alchemy Robinhood Chain HTTPS URL
PULSE_PRIVATE_KEY=     # hot wallet key — live mode only
ANTHROPIC_API_KEY=     # optional, LLM command-parse fallback
PULSE_CA_BUNDLE=       # optional: path to proxy/AV CA PEM if TLS verify still fails
